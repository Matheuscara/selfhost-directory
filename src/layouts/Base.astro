---
import '../styles/global.css';
import Mascot from '../components/Mascot.astro';
const { title, description, noindex } = Astro.props as { title: string; description?: string; noindex?: boolean };
const desc = description ?? 'A directory of self-hosted and open source alternatives. Find the right app to run on your own server.';
const SITE_NAME = 'SelfHost Directory';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // aplica o tema antes da pintura (evita flash). Padrão: preferência do sistema.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-line bg-panel/80 backdrop-blur sticky top-0 z-10 shadow-sm">
      <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center gap-5 text-sm font-medium">
        <a href="/" class="font-bold text-ink text-base flex items-center gap-2">
          <Mascot class="w-8 h-8" animate={false} />
          <span>{SITE_NAME}</span>
        </a>
        <a href="/categories" class="text-muted hover:text-ink px-2 py-1 rounded-md hover:bg-panel-2 transition">Categories</a>
        <a href="/alternatives" class="text-muted hover:text-ink px-2 py-1 rounded-md hover:bg-panel-2 transition">Alternatives</a>
        <a href="/comparisons" class="text-muted hover:text-ink px-2 py-1 rounded-md hover:bg-panel-2 transition hidden sm:inline">Comparisons</a>
        <a href="/search" class="text-muted hover:text-ink px-2 py-1 rounded-md hover:bg-panel-2 transition">Search</a>
        <button id="theme-toggle" type="button" aria-label="Toggle dark mode"
                class="ml-auto w-9 h-9 flex items-center justify-center rounded-md text-muted hover:text-ink hover:bg-panel-2 transition text-base">🌙</button>
        <a href="/advertise" class="px-3 py-1.5 rounded-lg bg-accent text-white hover:opacity-90 transition">Advertise</a>
      </nav>
    </header>

    <main class="flex-1 w-full max-w-6xl mx-auto px-4 py-8" data-pagefind-body>
      <slot />
    </main>

    <footer class="border-t border-line mt-16 bg-panel">
      <div class="max-w-6xl mx-auto px-4 py-10 text-xs text-muted space-y-2">
        <p class="flex flex-wrap gap-x-4 gap-y-1">
          <a href="/about" class="hover:text-ink">About</a>
          <a href="/advertise" class="hover:text-ink">Advertise</a>
          <a href="/categories" class="hover:text-ink">Categories</a>
          <a href="/alternatives" class="hover:text-ink">Alternatives</a>
          <a href="/comparisons" class="hover:text-ink">Comparisons</a>
          <a href="https://github.com/awesome-selfhosted/awesome-selfhosted-data" target="_blank" rel="noopener" class="hover:text-ink">Data ↗</a>
        </p>
        <p>{SITE_NAME} — data from <a class="underline" href="https://github.com/awesome-selfhosted/awesome-selfhosted-data" target="_blank" rel="noopener">awesome-selfhosted</a> (CC-BY-SA 3.0).</p>
        <p>Some hosting links are affiliate links. This doesn't change the price for you and helps keep the site running.</p>
      </div>
    </footer>

    <script is:inline>
      // rastro do mouse: pontinhos que aparecem no caminho e somem (cursor nativo intacto)
      (function () {
        if (!window.matchMedia || !window.matchMedia('(pointer: fine)').matches) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var N = 16, dots = [], i = 0;
        for (var k = 0; k < N; k++) {
          var d = document.createElement('div');
          d.className = 'trail-dot';
          document.body.appendChild(d);
          dots.push(d);
        }
        window.addEventListener('mousemove', function (e) {
          var d = dots[i];
          i = (i + 1) % N;
          d.style.transition = 'none';
          d.style.left = e.clientX + 'px';
          d.style.top = e.clientY + 'px';
          d.style.opacity = '0.6';
          d.style.transform = 'translate(-50%, -50%) scale(1)';
          void d.offsetWidth; // força reflow p/ reiniciar a transição
          d.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          d.style.opacity = '0';
          d.style.transform = 'translate(-50%, -50%) scale(0.2)';
        });
      })();
    </script>

    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function sync() { btn.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙'; }
        sync();
        btn.addEventListener('click', function () {
          var dark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
          sync();
        });
      })();
    </script>
  </body>
</html>
