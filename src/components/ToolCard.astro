---
import type { Software } from '../lib/data';
import Favicon from './Favicon.astro';
const { tool } = Astro.props as { tool: Software };
---
<a href={`/tools/${tool.slug}`}
   class="group block rounded-xl border border-line bg-panel p-4 h-full shadow-sm hover:shadow-md hover:border-accent/40 hover:-translate-y-0.5 transition-all duration-200">
  <div class="flex items-start gap-3">
    <Favicon url={tool.website_url} />
    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-2">
        <h3 class="font-semibold text-ink group-hover:text-accent transition-colors truncate">{tool.name}</h3>
        {tool.stargazers_count > 0 && (
          <span class="text-xs text-muted whitespace-nowrap">★ {tool.stargazers_count.toLocaleString('pt-BR')}</span>
        )}
      </div>
    </div>
  </div>
  <p class="text-sm text-muted mt-2 line-clamp-3" set:html={(tool.editorial ?? tool.descriptionHtml)}></p>
  <div class="flex flex-wrap gap-1 mt-3">
    {tool.tags.slice(0, 2).map((t) => (
      <span class="text-[11px] px-2 py-0.5 rounded-full border border-line text-muted">{t}</span>
    ))}
    {tool.licenses.slice(0, 1).map((l) => (
      <span class="text-[11px] px-2 py-0.5 rounded-full bg-teal-50 text-accent-2">{l}</span>
    ))}
  </div>
</a>
