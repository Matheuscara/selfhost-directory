---
import Base from '../layouts/Base.astro';
import { getComparisons } from '../lib/data';
const comparisons = getComparisons();
---
<Base title="Comparações de ferramentas self-hosted (X vs Y)"
      description="Comparativos das melhores ferramentas self-hosted e open source: licença, popularidade e recursos lado a lado.">
  <h1 class="text-3xl font-bold text-ink">Comparações</h1>
  <p class="text-muted mt-2">Qual a melhor opção self-hosted? Veja comparativos lado a lado.</p>
  <div class="grid sm:grid-cols-2 gap-3 mt-6">
    {comparisons.map((c) => (
      <a href={`/vs/${c.slug}`} class="rounded-lg border border-line bg-panel hover:bg-panel-2 p-4 transition">
        <span class="text-ink font-medium">{c.title}</span>
        <span class="block text-sm text-muted mt-1 line-clamp-2">{c.intro}</span>
      </a>
    ))}
  </div>
</Base>
