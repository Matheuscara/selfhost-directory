---
import Base from '../../layouts/Base.astro';
import ToolCard from '../../components/ToolCard.astro';
import HostingBox from '../../components/HostingBox.astro';
import { getAlternatives, getAlternative, toolsForAlternative } from '../../lib/data';

export function getStaticPaths() {
  return getAlternatives().map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const alt = getAlternative(slug!)!;
const tools = toolsForAlternative(alt);
const top = tools[0];
const names = tools.slice(0, 3).map((t) => t.name).join(', ');

const faq = [
  {
    q: `Is there a free self-hosted alternative to ${alt.proprietary}?`,
    a: tools.length
      ? `Yes. We've gathered ${tools.length} self-hosted, open source alternatives to ${alt.proprietary} — including ${names}. You run all of them on your own server.`
      : `We'll soon list self-hosted alternatives to ${alt.proprietary}.`,
  },
  {
    q: `What is the best open source alternative to ${alt.proprietary}?`,
    a: top
      ? `${top.name} is one of the most popular (${top.stargazers_count.toLocaleString('en-US')} GitHub stars). The "best" depends on your case — compare the options below.`
      : `We're still evaluating the best options.`,
  },
  {
    q: `Do I need a server to replace ${alt.proprietary}?`,
    a: `Yes. You can use a home server (homelab) or a cheap VPS (from ~€4/mo). See the hosting suggestions on this page.`,
  },
];

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'Alternatives', item: new URL('/alternatives', Astro.site).href },
        { '@type': 'ListItem', position: 3, name: `Alternative to ${alt.proprietary}` },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'ItemList',
      itemListElement: tools.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: t.name,
        url: new URL(`/tools/${t.slug}`, Astro.site).href,
      })),
    },
  ],
};
---
<Base title={`Self-hosted alternatives to ${alt.proprietary}`}
      description={`The ${tools.length} best self-hosted, open source alternatives to ${alt.proprietary}. ${alt.blurb}`.slice(0, 160)}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} is:inline />

  <nav class="text-xs text-muted mb-4"><a href="/alternatives" class="hover:text-ink">Alternatives</a> / <span class="text-ink">{alt.proprietary}</span></nav>
  <h1 class="text-3xl font-bold text-ink">Self-hosted alternatives to {alt.proprietary}</h1>
  <p class="text-muted mt-3 max-w-3xl">
    {alt.blurb} Below are {tools.length} open source options you host on your own server —
    with no monthly per-user fee and full control of your data.
  </p>

  <div class="grid lg:grid-cols-3 gap-8 mt-8">
    <div class="lg:col-span-2">
      <div class="grid sm:grid-cols-2 gap-4">
        {tools.map((t) => <ToolCard tool={t} />)}
      </div>
      {tools.length === 0 && <p class="text-muted">Coming soon.</p>}

      <section class="mt-12">
        <h2 class="text-xl font-semibold text-ink mb-4">Frequently asked questions</h2>
        <div class="space-y-4">
          {faq.map((f) => (
            <details class="rounded-lg border border-line bg-panel p-4">
              <summary class="font-medium text-ink cursor-pointer">{f.q}</summary>
              <p class="text-sm text-muted mt-2">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
    <div class="lg:col-span-1">
      <HostingBox />
    </div>
  </div>
</Base>
