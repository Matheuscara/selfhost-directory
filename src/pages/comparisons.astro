---
import Base from '../layouts/Base.astro';
import { getComparisons } from '../lib/data';
const comparisons = getComparisons();
---
<Base title="Self-hosted tool comparisons (X vs Y)"
      description="Comparisons of the best self-hosted and open source tools: license, popularity and features side by side.">
  <h1 class="text-3xl font-bold text-ink">Comparisons</h1>
  <p class="text-muted mt-2">Which self-hosted option is best? See side-by-side comparisons.</p>
  <div class="grid sm:grid-cols-2 gap-3 mt-6">
    {comparisons.map((c) => (
      <a href={`/vs/${c.slug}`} class="rounded-lg border border-line bg-panel hover:bg-panel-2 p-4 transition">
        <span class="text-ink font-medium">{c.title}</span>
        <span class="block text-sm text-muted mt-1 line-clamp-2">{c.intro}</span>
      </a>
    ))}
  </div>
</Base>
