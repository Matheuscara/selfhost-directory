---
import Base from '../../layouts/Base.astro';
import ToolCard from '../../components/ToolCard.astro';
import HostingBox from '../../components/HostingBox.astro';
import { getCategories, getCategory, softwareByTag } from '../../lib/data';

export function getStaticPaths() {
  return getCategories().map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = getCategory(slug!)!;
const tools = softwareByTag(cat.name);
const names = tools.slice(0, 3).map((t) => t.name).join(', ');

const faq = [
  {
    q: `What are the best self-hosted ${cat.name} tools?`,
    a: tools.length
      ? `Among the ${tools.length} options, the most popular include ${names}. Compare license, platform and popularity in the list below.`
      : `We're still cataloguing the options.`,
  },
  {
    q: `Is there a free open source alternative for ${cat.name}?`,
    a: `Yes — all ${tools.length} tools on this page are open source and you run them on your own server, with no monthly fee.`,
  },
  {
    q: `Where can I host a ${cat.name} app?`,
    a: `On a home server (homelab) or a cheap VPS from ~€4/mo. See the suggestions on this page.`,
  },
];

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'Categories', item: new URL('/categories', Astro.site).href },
        { '@type': 'ListItem', position: 3, name: cat.name },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
    },
    {
      '@type': 'ItemList',
      itemListElement: tools.map((t, i) => ({ '@type': 'ListItem', position: i + 1, name: t.name, url: new URL(`/tools/${t.slug}`, Astro.site).href })),
    },
  ],
};
---
<Base title={`${cat.name} self-hosted — open source`}
      description={`The ${tools.length} best self-hosted ${cat.name} tools. Open source alternatives you run on your own server, with no monthly fee.`.slice(0, 160)}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} is:inline />

  <nav class="text-xs text-muted mb-4"><a href="/categories" class="hover:text-ink">Categories</a> / <span class="text-ink">{cat.name}</span></nav>
  <h1 class="text-3xl font-bold text-ink">Best self-hosted {cat.name} apps</h1>
  {cat.description && <p class="text-muted mt-3 max-w-3xl prose" set:html={cat.descriptionHtml}></p>}
  <p class="text-muted mt-2 max-w-3xl">
    {tools.length} open source {cat.name} tools you host on your own server —
    with full control of your data and no per-user cost.
  </p>

  <div class="grid lg:grid-cols-3 gap-8 mt-6">
    <div class="lg:col-span-2">
      <div class="grid sm:grid-cols-2 gap-4">
        {tools.map((t) => <ToolCard tool={t} />)}
      </div>

      <section class="mt-12">
        <h2 class="text-xl font-semibold text-ink mb-4">Frequently asked questions</h2>
        <div class="space-y-4">
          {faq.map((f) => (
            <details class="rounded-lg border border-line bg-panel p-4">
              <summary class="font-medium text-ink cursor-pointer">{f.q}</summary>
              <p class="text-sm text-muted mt-2">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
    <div class="lg:col-span-1">
      <HostingBox />
    </div>
  </div>
</Base>
