---
import Base from '../layouts/Base.astro';
import { getSoftware } from '../lib/data';

// edite quando definir domínio/preço
const CONTACT = 'contato@SEUDOMINIO.com';
const total = getSoftware().length;

const tiers = [
  { name: 'Destaque na categoria', price: '$29/mês', perks: ['Topo de 1 categoria à sua escolha', 'Selo "Patrocinado"', 'Link do-follow pro seu site'] },
  { name: 'Destaque na home', price: '$79/mês', perks: ['Slot fixo na página inicial', 'Aparece em todas as buscas', 'Tudo do plano anterior'] },
  { name: 'Takeover', price: '$199/mês', perks: ['Home + 3 categorias', 'Banner no topo do site', 'Relatório mensal de cliques'] },
];
---
<Base title="Anuncie no SelfHost Directory — alcance quem busca self-hosting"
      description="Coloque sua ferramenta, hospedagem ou produto na frente de um público técnico que busca soluções self-hosted e open source.">
  <section class="text-center py-8">
    <h1 class="text-3xl font-bold text-ink">Coloque sua ferramenta na frente de quem decide</h1>
    <p class="text-muted mt-3 max-w-2xl mx-auto">
      Nosso público é técnico e de alta intenção: devs, sysadmins e entusiastas de homelab procurando
      ativamente o que instalar no próprio servidor. Anuncie ao lado de {total.toLocaleString('pt-BR')} ferramentas.
    </p>
  </section>

  <div class="grid md:grid-cols-3 gap-4 mt-6">
    {tiers.map((t, i) => (
      <div class={`rounded-xl border p-5 ${i === 1 ? 'border-accent bg-panel-2' : 'border-line bg-panel'}`}>
        {i === 1 && <span class="text-[11px] px-2 py-0.5 rounded-full bg-accent/20 text-accent">mais popular</span>}
        <h2 class="text-lg font-semibold text-ink mt-2">{t.name}</h2>
        <p class="text-2xl font-bold text-ink mt-1">{t.price}</p>
        <ul class="mt-4 space-y-2 text-sm text-muted">
          {t.perks.map((p) => <li>✓ {p}</li>)}
        </ul>
        <a href={`mailto:${CONTACT}?subject=${encodeURIComponent('Anúncio — ' + t.name)}`}
           class="block text-center mt-5 px-4 py-2 rounded-lg bg-accent text-bg text-sm font-medium">Quero este</a>
      </div>
    ))}
  </div>

  <section class="mt-12 max-w-2xl">
    <h2 class="text-xl font-semibold text-ink mb-3">Como funciona</h2>
    <ol class="space-y-2 text-sm text-muted list-decimal list-inside">
      <li>Você escolhe o plano e manda nome, link e um texto curto pra <a class="underline text-accent" href={`mailto:${CONTACT}`}>{CONTACT}</a>.</li>
      <li>Publicamos seu destaque em até 48h.</li>
      <li>Cancelamento a qualquer momento. Sem fidelidade.</li>
    </ol>
    <p class="text-xs text-muted mt-6">Preços de lançamento — sujeitos a ajuste conforme o tráfego cresce.</p>
  </section>
</Base>
