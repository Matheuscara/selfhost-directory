---
import Base from '../layouts/Base.astro';
import { getCategories } from '../lib/data';
const categories = getCategories();
---
<Base title="All self-hosted software categories">
  <h1 class="text-3xl font-bold text-ink">Categories</h1>
  <p class="text-muted mt-2">{categories.length} categories of open source apps for self-hosting.</p>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-6">
    {categories.map((c) => (
      <a href={`/category/${c.slug}`}
         class="flex items-center justify-between rounded-lg border border-line bg-panel hover:bg-panel-2 p-3 transition">
        <span class="text-sm text-ink">{c.name}</span>
        <span class="text-xs text-muted">{c.count}</span>
      </a>
    ))}
  </div>
</Base>
