---
import Base from '../../layouts/Base.astro';
import ToolCard from '../../components/ToolCard.astro';
import HostingBox from '../../components/HostingBox.astro';
import Favicon from '../../components/Favicon.astro';
import { getSoftware, getTool, relatedTools, slugify } from '../../lib/data';

export function getStaticPaths() {
  return getSoftware().map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const tool = getTool(slug!)!;
const related = relatedTools(tool);
const plainDesc = tool.description.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1');
const baseDesc = tool.editorial || plainDesc;
const metaDesc = (baseDesc.length < 110
  ? `${baseDesc} ${tool.name} é uma alternativa self-hosted open source.`
  : baseDesc).slice(0, 160);

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: tool.name,
      description: plainDesc,
      applicationCategory: tool.tags[0],
      operatingSystem: tool.platforms.join(', ') || 'Self-hosted',
      url: tool.website_url,
      ...(tool.source_code_url && { softwareHelp: tool.source_code_url }),
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início', item: new URL('/', Astro.site).href },
        ...(tool.tags[0] ? [{ '@type': 'ListItem', position: 2, name: tool.tags[0], item: new URL(`/category/${slugify(tool.tags[0])}`, Astro.site).href }] : []),
        { '@type': 'ListItem', position: 3, name: tool.name },
      ],
    },
  ],
};
---
<Base title={`${tool.name} — alternativa self-hosted open source`}
      description={metaDesc}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} is:inline />
  <nav class="text-xs text-muted mb-4">
    <a href="/" class="hover:text-ink">Início</a> /
    {tool.tags[0] && <a href={`/category/${slugify(tool.tags[0])}`} class="hover:text-ink">{tool.tags[0]}</a>} /
    <span class="text-ink">{tool.name}</span>
  </nav>

  <div class="grid lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
      <div class="flex items-center gap-3">
        <Favicon url={tool.website_url} class="w-12 h-12" />
        <h1 class="text-3xl font-bold text-ink">{tool.name}</h1>
      </div>
      {tool.editorial
        ? <>
            <p class="text-ink/90 mt-3 leading-relaxed">{tool.editorial}</p>
            <p class="text-sm text-muted mt-3 prose">Resumo do projeto: <span set:html={tool.descriptionHtml}></span></p>
          </>
        : <p class="text-muted mt-3 prose" set:html={tool.descriptionHtml}></p>}

      <div class="flex flex-wrap gap-2 mt-5">
        {tool.website_url && <a class="px-3 py-1.5 rounded-lg bg-accent text-white text-sm font-medium" href={tool.website_url} target="_blank" rel="noopener">Site oficial ↗</a>}
        {tool.source_code_url && <a class="px-3 py-1.5 rounded-lg border border-line text-sm" href={tool.source_code_url} target="_blank" rel="noopener">Código-fonte</a>}
        {tool.demo_url && <a class="px-3 py-1.5 rounded-lg border border-line text-sm" href={tool.demo_url} target="_blank" rel="noopener">Demo</a>}
      </div>

      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6 text-sm">
        <div><dt class="text-muted">Estrelas</dt><dd class="text-ink">{tool.stargazers_count.toLocaleString('pt-BR')}</dd></div>
        <div><dt class="text-muted">Licença</dt><dd class="text-ink">{tool.licenses.join(', ') || '—'}</dd></div>
        <div><dt class="text-muted">Plataforma</dt><dd class="text-ink">{tool.platforms.join(', ') || '—'}</dd></div>
        <div><dt class="text-muted">Versão</dt><dd class="text-ink">{tool.current_release?.tag || '—'}</dd></div>
      </dl>

      <div class="flex flex-wrap gap-2 mt-6">
        {tool.tags.map((t) => (
          <a href={`/category/${slugify(t)}`} class="text-xs px-2 py-1 rounded-full border border-line text-muted hover:text-ink">{t}</a>
        ))}
      </div>
    </div>

    <div class="lg:col-span-1 space-y-6">
      {tool.website_url && (
        <a href={tool.website_url} target="_blank" rel="noopener" class="block rounded-xl border border-line bg-panel overflow-hidden shadow-sm hover:shadow-md transition">
          <img
            src={`https://s0.wp.com/mshots/v1/${encodeURIComponent(tool.website_url)}?w=640`}
            alt={`Captura de tela do ${tool.name}`}
            width="640" height="400" loading="lazy" decoding="async"
            class="w-full aspect-[16/10] object-cover object-top bg-panel-2"
          />
          <span class="block text-xs text-muted px-3 py-2">Prévia do site oficial ↗</span>
        </a>
      )}
      <HostingBox toolName={tool.name} />
    </div>
  </div>

  {related.length > 0 && (
    <section class="mt-12">
      <h2 class="text-lg font-semibold text-ink mb-3">Alternativas parecidas</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {related.map((t) => <ToolCard tool={t} />)}
      </div>
    </section>
  )}
</Base>
