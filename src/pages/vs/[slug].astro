---
import Base from '../../layouts/Base.astro';
import HostingBox from '../../components/HostingBox.astro';
import Favicon from '../../components/Favicon.astro';
import { getComparisons, getComparison, slugify } from '../../lib/data';

export function getStaticPaths() {
  return getComparisons().map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cmp = getComparison(slug!)!;
const names = cmp.tools.map((t) => t.name);
const maxStars = Math.max(...cmp.tools.map((t) => t.stargazers_count), 1);

const faq = [
  {
    q: `Which is the best self-hosted alternative among ${names.join(', ')}?`,
    a: `It depends on your case. ${names[0]} is the most popular (${cmp.tools[0].stargazers_count.toLocaleString('en-US')} stars). Compare license, platform and features in the table above.`,
  },
  {
    q: `Are ${names.join(', ')} free?`,
    a: `Yes, they're all open source and self-hosted — you run them on your own server with no monthly fee.`,
  },
];

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
    },
    {
      '@type': 'ItemList',
      itemListElement: cmp.tools.map((t, i) => ({ '@type': 'ListItem', position: i + 1, name: t.name, url: new URL(`/tools/${t.slug}`, Astro.site).href })),
    },
  ],
};
---
<Base title={`${cmp.title} — self-hosted comparison`}
      description={`${cmp.title} compared: license, popularity and features. ${cmp.intro}`.slice(0, 160)}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} is:inline />

  <nav class="text-xs text-muted mb-4"><a href="/comparisons" class="hover:text-ink">Comparisons</a> / <span class="text-ink">{cmp.title}</span></nav>
  <h1 class="text-3xl font-bold text-ink">{cmp.title}</h1>
  <p class="text-muted mt-3 max-w-3xl">{cmp.intro}</p>

  <div class="overflow-x-auto mt-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="text-left text-muted border-b border-line">
          <th class="py-2 pr-4 font-medium">Tool</th>
          <th class="py-2 pr-4 font-medium">★ GitHub</th>
          <th class="py-2 pr-4 font-medium">License</th>
          <th class="py-2 pr-4 font-medium">Platform</th>
        </tr>
      </thead>
      <tbody>
        {cmp.tools.map((t) => (
          <tr class="border-b border-line">
            <td class="py-3 pr-4">
              <a href={`/tools/${t.slug}`} class="flex items-center gap-2 text-accent hover:underline font-medium">
                <Favicon url={t.website_url} class="w-6 h-6" />{t.name}
              </a>
            </td>
            <td class="py-3 pr-4 text-ink">{t.stargazers_count.toLocaleString('en-US')}</td>
            <td class="py-3 pr-4 text-muted">{t.licenses.join(', ') || '—'}</td>
            <td class="py-3 pr-4 text-muted">{t.platforms.slice(0, 3).join(', ') || '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <section class="mt-8 rounded-xl border border-line bg-panel p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-muted uppercase tracking-wide mb-4">Popularity (★ on GitHub)</h2>
    {cmp.tools.map((t) => (
      <div class="flex items-center gap-3 mb-2.5">
        <span class="w-28 sm:w-36 truncate text-sm text-ink">{t.name}</span>
        <div class="flex-1 bg-panel-2 rounded-full h-5 overflow-hidden">
          <div class="h-full bg-accent rounded-full" style={`width:${((t.stargazers_count / maxStars) * 100).toFixed(1)}%`}></div>
        </div>
        <span class="text-xs text-muted w-16 text-right">{t.stargazers_count.toLocaleString('en-US')}</span>
      </div>
    ))}
  </section>

  <div class="grid lg:grid-cols-3 gap-8 mt-10">
    <div class="lg:col-span-2 space-y-6">
      {cmp.tools.map((t) => (
        <div class="rounded-xl border border-line bg-panel p-5">
          <div class="flex items-center justify-between">
            <h2 class="font-semibold text-ink"><a href={`/tools/${t.slug}`} class="hover:underline">{t.name}</a></h2>
            <a href={`/category/${slugify(t.tags[0] || '')}`} class="text-xs text-muted hover:text-ink">{t.tags[0]}</a>
          </div>
          <p class="text-sm text-muted mt-2">{t.editorial || t.description.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')}</p>
        </div>
      ))}

      <section class="mt-4">
        <h2 class="text-xl font-semibold text-ink mb-4">Frequently asked questions</h2>
        <div class="space-y-4">
          {faq.map((f) => (
            <details class="rounded-lg border border-line bg-panel p-4">
              <summary class="font-medium text-ink cursor-pointer">{f.q}</summary>
              <p class="text-sm text-muted mt-2">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
    <div class="lg:col-span-1"><HostingBox /></div>
  </div>
</Base>
