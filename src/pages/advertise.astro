---
import Base from '../layouts/Base.astro';
import { getSoftware } from '../lib/data';

// edit when you set your contact email / pricing
const CONTACT = 'contact@YOURDOMAIN.com';
const total = getSoftware().length;

const tiers = [
  { name: 'Category feature', price: '$29/mo', perks: ['Top of 1 category of your choice', '"Sponsored" badge', 'Do-follow link to your site'] },
  { name: 'Homepage feature', price: '$79/mo', perks: ['Fixed slot on the homepage', 'Shown across all searches', 'Everything in the previous plan'] },
  { name: 'Takeover', price: '$199/mo', perks: ['Homepage + 3 categories', 'Banner at the top of the site', 'Monthly click report'] },
];
---
<Base title="Advertise on SelfHost Directory — reach people looking for self-hosting"
      description="Put your tool, hosting or product in front of a technical audience actively looking for self-hosted and open source solutions.">
  <section class="text-center py-8">
    <h1 class="text-3xl font-bold text-ink">Put your tool in front of decision-makers</h1>
    <p class="text-muted mt-3 max-w-2xl mx-auto">
      Our audience is technical and high-intent: developers, sysadmins and homelab enthusiasts actively
      looking for what to install on their own server. Advertise alongside {total.toLocaleString('en-US')} tools.
    </p>
  </section>

  <div class="grid md:grid-cols-3 gap-4 mt-6">
    {tiers.map((t, i) => (
      <div class={`rounded-xl border p-5 ${i === 1 ? 'border-accent bg-panel-2' : 'border-line bg-panel'}`}>
        {i === 1 && <span class="text-[11px] px-2 py-0.5 rounded-full bg-accent/20 text-accent">most popular</span>}
        <h2 class="text-lg font-semibold text-ink mt-2">{t.name}</h2>
        <p class="text-2xl font-bold text-ink mt-1">{t.price}</p>
        <ul class="mt-4 space-y-2 text-sm text-muted">
          {t.perks.map((p) => <li>✓ {p}</li>)}
        </ul>
        <a href={`mailto:${CONTACT}?subject=${encodeURIComponent('Advertising — ' + t.name)}`}
           class="block text-center mt-5 px-4 py-2 rounded-lg bg-accent text-white text-sm font-medium">I want this</a>
      </div>
    ))}
  </div>

  <section class="mt-12 max-w-2xl">
    <h2 class="text-xl font-semibold text-ink mb-3">How it works</h2>
    <ol class="space-y-2 text-sm text-muted list-decimal list-inside">
      <li>Pick a plan and send your name, link and a short blurb to <a class="underline text-accent" href={`mailto:${CONTACT}`}>{CONTACT}</a>.</li>
      <li>We publish your feature within 48h.</li>
      <li>Cancel any time. No lock-in.</li>
    </ol>
    <p class="text-xs text-muted mt-6">Launch pricing — subject to change as traffic grows.</p>
  </section>
</Base>
