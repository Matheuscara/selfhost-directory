---
import Base from '../layouts/Base.astro';
---
<Base title="Página não encontrada — SelfHost Directory">
  <section class="text-center py-20">
    <h1 class="text-5xl font-bold text-ink">404</h1>
    <p class="text-muted mt-3">Essa página não existe (ou foi desativada).</p>
    <div class="flex gap-3 justify-center mt-6 text-sm">
      <a href="/" class="px-4 py-2 rounded-lg bg-accent text-white font-medium">Início</a>
      <a href="/categories" class="px-4 py-2 rounded-lg border border-line">Categorias</a>
      <a href="/alternatives" class="px-4 py-2 rounded-lg border border-line">Alternativas</a>
    </div>
  </section>
</Base>
