---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — SelfHost Directory">
  <section class="text-center py-20">
    <h1 class="text-5xl font-bold text-ink">404</h1>
    <p class="text-muted mt-3">This page doesn't exist (or was taken down).</p>
    <div class="flex gap-3 justify-center mt-6 text-sm">
      <a href="/" class="px-4 py-2 rounded-lg bg-accent text-white font-medium">Home</a>
      <a href="/categories" class="px-4 py-2 rounded-lg border border-line">Categories</a>
      <a href="/alternatives" class="px-4 py-2 rounded-lg border border-line">Alternatives</a>
    </div>
  </section>
</Base>
