---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import FeaturedRow from '../components/FeaturedRow.astro';
import { getSoftware, getCategories, getAlternatives, getComparisons } from '../lib/data';

const software = getSoftware();
const categories = getCategories();
const alternatives = getAlternatives();
const comparisons = getComparisons().slice(0, 8);
const popular = software.slice(0, 12);
const topCats = categories.slice(0, 12);
---
<Base title="SelfHost Directory — alternativas self-hosted e open source">
  <section class="hero-gradient rounded-3xl border border-line text-center px-4 py-16 sm:py-20 -mt-2">
    <span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-white/70 border border-line text-accent">
      {software.length.toLocaleString('pt-BR')} apps open source catalogados
    </span>
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-ink mt-5 max-w-3xl mx-auto">
      Pare de alugar software. <span class="text-accent">Rode você mesmo.</span>
    </h1>
    <p class="text-muted mt-4 max-w-2xl mx-auto text-base sm:text-lg">
      Pra quase todo serviço pago existe uma alternativa self-hosted e open source.
      Encontre a sua — sem mensalidade e com controle total dos seus dados.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/buscar" class="px-6 py-3 rounded-xl bg-accent text-white font-semibold text-sm shadow-sm hover:opacity-90 transition">🔍 Buscar {software.length.toLocaleString('pt-BR')} apps</a>
      <a href="/alternatives" class="px-6 py-3 rounded-xl bg-white border border-line text-ink font-semibold text-sm shadow-sm hover:bg-panel-2 transition">Trocar um serviço pago</a>
    </div>
  </section>

  <FeaturedRow />

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-ink mb-3">Trocar um serviço pago</h2>
    <div class="flex flex-wrap gap-2">
      {alternatives.map((a) => (
        <a href={`/alternative-to/${a.slug}`}
           class="text-sm px-3 py-1.5 rounded-full border border-line text-muted hover:text-ink hover:border-accent transition">
          alternativa a {a.proprietary}
        </a>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-ink mb-3">Categorias populares</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {topCats.map((c) => (
        <a href={`/category/${c.slug}`}
           class="flex items-center justify-between rounded-lg border border-line bg-panel hover:bg-panel-2 p-3 transition">
          <span class="text-sm text-ink">{c.name}</span>
          <span class="text-xs text-muted">{c.count}</span>
        </a>
      ))}
    </div>
    <a href="/categories" class="inline-block mt-3 text-sm text-accent hover:underline">Ver todas as {categories.length} categorias →</a>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-ink mb-3">Comparações populares</h2>
    <div class="flex flex-wrap gap-2">
      {comparisons.map((c) => (
        <a href={`/vs/${c.slug}`}
           class="text-sm px-3 py-1.5 rounded-full border border-line text-muted hover:text-ink hover:border-accent transition">
          {c.title}
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-ink mb-3">Mais populares</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {popular.map((t) => <ToolCard tool={t} />)}
    </div>
  </section>
</Base>
