---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import FeaturedRow from '../components/FeaturedRow.astro';
import Mascot from '../components/Mascot.astro';
import { getSoftware, getCategories, getAlternatives, getComparisons } from '../lib/data';

const software = getSoftware();
const categories = getCategories();
const alternatives = getAlternatives();
const comparisons = getComparisons().slice(0, 8);
const popular = software.slice(0, 12);
const topCats = categories.slice(0, 12);
const DEFAULT_ALTS = 12;
---
<Base title="SelfHost Directory — alternativas self-hosted e open source">
  <section class="hero-gradient rounded-3xl border border-line px-6 py-12 sm:py-16">
    <div class="grid md:grid-cols-2 gap-10 items-center max-w-5xl mx-auto">
      <div class="text-center md:text-left order-2 md:order-1">
        <span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-white/70 border border-line text-accent">
          {software.length.toLocaleString('pt-BR')} apps open source catalogados
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-ink mt-5">
          Pare de alugar software. <span class="text-accent">Rode você mesmo.</span>
        </h1>
        <p class="text-muted mt-4 text-base sm:text-lg">
          Pra quase todo serviço pago existe uma alternativa self-hosted e open source.
          Encontre a sua — sem mensalidade e com seus dados sob seu controle.
        </p>
        <div class="mt-8 flex flex-wrap justify-center md:justify-start gap-3">
          <a href="/buscar" class="px-6 py-3 rounded-xl bg-accent text-white font-semibold text-sm shadow-sm hover:opacity-90 transition">🔍 Buscar {software.length.toLocaleString('pt-BR')} apps</a>
          <a href="/alternatives" class="px-6 py-3 rounded-xl bg-white border border-line text-ink font-semibold text-sm shadow-sm hover:bg-panel-2 transition">Ver alternativas</a>
        </div>
      </div>
      <div class="flex justify-center md:justify-end order-1 md:order-2">
        <Mascot class="w-44 h-44 sm:w-60 sm:h-60 drop-shadow-md" />
      </div>
    </div>
  </section>

  <FeaturedRow />

  <section class="mb-12 mt-12">
    <h2 class="text-2xl font-bold text-ink">Trocar um serviço pago</h2>
    <p class="text-muted mt-1">Digite o serviço que você quer substituir.</p>

    <div class="relative mt-4 max-w-xl">
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted">🔍</span>
      <input id="alt-search" type="text" autocomplete="off"
             placeholder="Ex.: Notion, Google Drive, Slack, Spotify…"
             class="w-full rounded-xl border border-line bg-panel pl-11 pr-4 py-3 text-ink shadow-sm focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent transition" />
    </div>

    <div id="alt-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-5">
      {alternatives.map((a, i) => (
        <a href={`/alternative-to/${a.slug}`} data-alt={a.proprietary.toLowerCase()}
           class={`alt-card rounded-xl border border-line bg-panel p-4 shadow-sm hover:shadow-md hover:border-accent/40 hover:-translate-y-0.5 transition-all ${i >= DEFAULT_ALTS ? 'hidden' : ''}`}>
          <span class="font-semibold text-ink">{a.proprietary}</span>
          <span class="block text-sm text-muted mt-1 line-clamp-2">{a.blurb}</span>
        </a>
      ))}
    </div>
    <p id="alt-empty" class="hidden text-muted text-sm mt-4">Nenhum serviço encontrado com esse nome. <a href="/alternatives" class="text-accent underline">Ver todos</a>.</p>
    <a href="/alternatives" class="inline-block mt-4 text-sm text-accent hover:underline">Ver todas as {alternatives.length} alternativas →</a>
  </section>

  <script is:inline define:vars={{ DEFAULT_ALTS }}>
    (function () {
      const input = document.getElementById('alt-search');
      const cards = Array.from(document.querySelectorAll('#alt-grid [data-alt]'));
      const empty = document.getElementById('alt-empty');
      if (!input) return;
      function apply() {
        const q = input.value.toLowerCase().trim();
        let shown = 0;
        cards.forEach((el, i) => {
          const show = q ? el.dataset.alt.includes(q) : i < DEFAULT_ALTS;
          el.classList.toggle('hidden', !show);
          if (show) shown++;
        });
        empty.classList.toggle('hidden', shown > 0 || !q);
      }
      input.addEventListener('input', apply);
    })();
  </script>

  <section class="mb-12">
    <h2 class="text-2xl font-bold text-ink mb-1">Categorias populares</h2>
    <p class="text-muted mb-4">Explore por tipo de aplicação.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {topCats.map((c) => (
        <a href={`/category/${c.slug}`}
           class="flex items-center justify-between rounded-xl border border-line bg-panel hover:bg-panel-2 hover:border-accent/40 p-4 shadow-sm transition">
          <span class="text-sm font-medium text-ink">{c.name}</span>
          <span class="text-xs text-muted bg-panel-2 rounded-full px-2 py-0.5">{c.count}</span>
        </a>
      ))}
    </div>
    <a href="/categories" class="inline-block mt-4 text-sm text-accent hover:underline">Ver todas as {categories.length} categorias →</a>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold text-ink mb-4">Comparações populares</h2>
    <div class="flex flex-wrap gap-2">
      {comparisons.map((c) => (
        <a href={`/vs/${c.slug}`}
           class="text-sm px-3 py-1.5 rounded-full border border-line bg-panel text-muted hover:text-ink hover:border-accent shadow-sm transition">
          {c.title}
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-bold text-ink mb-4">Mais populares</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {popular.map((t) => <ToolCard tool={t} />)}
    </div>
  </section>
</Base>
