{
  "name": "selfhost-directory",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fetch:data": "test -d data-src || git clone --depth 1 https://github.com/awesome-selfhosted/awesome-selfhosted-data.git data-src",
    "dev": "npm run fetch:data && astro dev",
    "build": "npm run fetch:data && astro build",
    "preview": "astro preview",
    "data:update": "git -C data-src pull --ff-only || (rm -rf data-src && npm run fetch:data)"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.8.0",
    "astro-pagefind": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.0",
    "tailwindcss": "^4.1.7"
  }
}
